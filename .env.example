# E-postkonfigurasjon (SMTP auto-detekteres basert paa domene)
# For Gmail: bruk App Password (https://myaccount.google.com/apppasswords)
EMAIL_USER=din@gmail.com
EMAIL_PASS=ditt-app-passord

# Mottaker av daglig nyhetsdigest
DIGEST_RECIPIENT_EMAIL=mottaker@email.com

# Valgfri: Vercel Cron Secret (anbefalt for produksjon)
# CRON_SECRET=en-tilfeldig-hemmelighet

# Valgfri: Anthropic API-nokkel for AI-oppsummering
# Aktiver AI-modus i src/lib/summarize.ts for aa bruke denne
# ANTHROPIC_API_KEY=sk-ant-...
